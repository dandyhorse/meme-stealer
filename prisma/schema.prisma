// Prisma schema for meme-stealer database.
// Defines the data models for tracking watched channels, deduplicated content, and admin users.

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
  // engineType = "client" // enable Prisma ORM without Rust
}

// PostgreSQL database connection — URL is provided via prisma.config.ts
datasource db {
  provider = "postgres"
}

// Admin roles: 'admin' can manage channels, 'full_access' can also manage other admins
enum AdminRole {
  admin
  full_access
}

// Stores authorized admin users who can interact with the help bot.
// Roles control which commands are available to each admin.
model Admin {
  id         Int       @id @default(autoincrement())
  telegramId BigInt    @unique @map("telegram_id")
  role       AdminRole @default(admin)
  name       String?
  createdAt  DateTime  @default(now()) @map("created_at")

  @@map("admins")
}

// Represents a Telegram channel being monitored for new memes.
// isActive controls whether the polling loop checks this channel.
// lastMessageId tracks the highest message ID already processed to avoid duplicates.
model Chat {
  id            Int      @id @default(autoincrement())
  chatId        BigInt   @unique
  title         String
  isActive      Boolean  @default(true) @map("is_active")
  lastMessageId Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  minithumbnails MinithumbnailSource[]

  @@index([isActive])
  @@map("chats")
}

// Stores the MD5 hash of a stripped thumbnail (~32x32 JPEG) for exact-match deduplication.
// Each unique hash represents a distinct piece of media content.
// isPostedToFilteredChat tracks whether this content has been flagged as a duplicate.
model Minithumbnail {
  id                     Int      @id @default(autoincrement())
  md5                    String   @unique @db.Char(32)
  isPostedToFilteredChat Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  // Channels where this content has appeared (many-to-many via MinithumbnailSource)
  channelsFrom MinithumbnailSource[]

  @@index([isPostedToFilteredChat])
  @@map("minithumbnails")
}

// Join table linking thumbnails to their source channels.
// Tracks which channels have posted a given piece of content.
// The unique constraint prevents duplicate entries for the same thumbnail-channel pair.
model MinithumbnailSource {
  id              Int           @id @default(autoincrement())
  minithumbnail   Minithumbnail @relation(fields: [minithumbnailId], references: [id], onDelete: Cascade)
  minithumbnailId Int
  chat            Chat          @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId          Int
  addedAt         DateTime      @default(now())

  @@unique([minithumbnailId, chatId])
  @@index([chatId])
  @@map("minithumbnail_sources")
}

// Tracks seen sticker pack IDs to avoid re-processing the same stickers.
// Currently unused but reserved for future sticker deduplication features.
model Sticker {
  id        Int      @id @default(autoincrement())
  setId     BigInt   @unique
  createdAt DateTime @default(now())

  @@map("stickers")
}
