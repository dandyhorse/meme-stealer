generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
  // engineType = "client" // enable Prisma ORM without Rust
}

datasource db {
  provider = "postgres"
}

enum AdminRole {
  admin
  full_access
}

model Admin {
  id         Int       @id @default(autoincrement())
  telegramId BigInt    @unique @map("telegram_id")
  role       AdminRole @default(admin)
  name       String?
  createdAt  DateTime  @default(now()) @map("created_at")

  @@map("admins")
}

model Chat {
  id            Int      @id @default(autoincrement())
  chatId        BigInt   @unique
  title         String
  isActive      Boolean  @default(true) @map("is_active")
  lastMessageId Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  minithumbnails MinithumbnailSource[]

  @@index([isActive])
  @@map("chats")
}

model Minithumbnail {
  id        Int      @id @default(autoincrement())
  md5       String?  @db.Char(32)
  phash     BigInt?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Каналы-источники этого контента                                                                                                                
  channelsFrom MinithumbnailSource[]

  @@index([phash])
  @@map("minithumbnails")
}

// Связующая таблица: из каких каналов пришёл контент                                                                                               
model MinithumbnailSource {
  id              Int           @id @default(autoincrement())
  minithumbnail   Minithumbnail @relation(fields: [minithumbnailId], references: [id], onDelete: Cascade)
  minithumbnailId Int
  chat            Chat          @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId          Int
  addedAt         DateTime      @default(now())

  @@unique([minithumbnailId, chatId])
  @@index([chatId])
  @@map("minithumbnail_sources")
}

model Sticker {
  id        Int      @id @default(autoincrement())
  setId     BigInt   @unique
  createdAt DateTime @default(now())

  @@map("stickers")
}
