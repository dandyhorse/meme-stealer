generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
  // engineType = "client" // enable Prisma ORM without Rust
}

datasource db {
  provider = "postgres"
}

enum AdminRole {
  admin
  full_access
}

model Admin {
  id         Int       @id @default(autoincrement())
  telegramId BigInt    @unique @map("telegram_id")
  role       AdminRole @default(admin)
  name       String?
  createdAt  DateTime  @default(now()) @map("created_at")

  @@map("admins")
}

model Chat {
  id            Int      @id @default(autoincrement())
  chatId        BigInt   @unique
  title         String
  isActive      Boolean  @default(true) @map("is_active")
  lastMessageId Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  contentHashes  ContentHashSource[]

  @@index([isActive])
  @@map("chats")
}

model ContentHash {
  id        Int      @id @default(autoincrement())
  phash     BigInt
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sources ContentHashSource[]

  @@index([phash])
  @@map("content_hashes")
}

model ContentHashSource {
  id            Int         @id @default(autoincrement())
  contentHash   ContentHash @relation(fields: [contentHashId], references: [id], onDelete: Cascade)
  contentHashId Int
  chat          Chat        @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId        Int
  messageId     Int
  sourceChatId  BigInt
  addedAt       DateTime    @default(now())

  @@unique([contentHashId, chatId])
  @@index([chatId])
  @@map("content_hash_sources")
}

model Sticker {
  id        Int      @id @default(autoincrement())
  setId     BigInt   @unique
  createdAt DateTime @default(now())

  @@map("stickers")
}
