{
  "name": "meme-bot-node",
  "version": "1.0.0",
  "description": "meme-stealer [repack by b@ri$ & 6rib@ch]",
  "license": "ISC",
  "author": "rundoom & dandyhorse",
  "lint-staged": {
    "{src,tests}/**/*.{js,ts}": [
      "eslint --fix"
    ]
  },
  "scripts": {
    "build": "eslint . && tsc",
    "seed": "npx tsx prisma/seed.ts",
    "dev": "nodemon --exec ts-node --require tsconfig-paths/register src/index.ts",
    "start": "node -r tsconfig-paths/register .build/src/index.js",
    "build-test": "npm run build",
    "prepare": "husky",
    "db:seed": "ts-node --require tsconfig-paths/register prisma/seed.ts",
    "connect": "npx ts-node --require tsconfig-paths/register connect.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "axios": "^1.13.2",
    "dotenv": "^17.2.3",
    "pg": "^8.17.1",
    "sharp": "^0.34.5",
    "socks": "^2.8.7",
    "socks-proxy-agent": "^10.0.0",
    "telegraf": "^4.16.3",
    "telegram": "^2.26.22",
    "tsconfig-paths": "^4.2.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/node": "^25.0.9",
    "@types/pg": "^8.16.0",
    "@types/sharp": "^0.31.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "nodemon": "^3.1.11",
    "prettier": "^3.8.0",
    "prisma": "^7.4.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.0"
  }
}
